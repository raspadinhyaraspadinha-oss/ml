RewriteEngine On

# ============================================
# LAYER 0: LiteSpeed Cache (MOST IMPACTFUL)
# LiteSpeed serves cached responses from MEMORY
# = ZERO PHP workers for cached pages
# ============================================

<IfModule LiteSpeed>
    # Cache static HTML pages for 1 hour
    RewriteRule \.(html?)$ - [E=Cache-Control:max-age=3600]

    # Cache static assets for 7 days (css, js, images, fonts)
    RewriteRule \.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff2?|ttf|eot)$ - [E=Cache-Control:max-age=604800]

    # Cache feature-flags and experiments (public, same for all users)
    RewriteRule ^api/feature-flags\.php$ - [E=Cache-Control:max-age=300]
    RewriteRule ^api/experiments\.php$ - [E=Cache-Control:max-age=600]

    # All OTHER PHP: no cache (skip feature-flags and experiments)
    RewriteCond %{REQUEST_URI} !^/api/feature-flags\.php$ [NC]
    RewriteCond %{REQUEST_URI} !^/api/experiments\.php$ [NC]
    RewriteRule \.php$ - [E=Cache-Control:no-cache]
</IfModule>

# ============================================
# LAYER 1: Bot Blocking (BEFORE any PHP)
# Blocks at server level = ZERO PHP workers
# ============================================

# ── Block known bad bots by User-Agent ──
# Ad crawlers (facebookexternalhit, whatsapp, etc.) are NOT blocked
RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|SemrushBot|MJ12bot|DotBot|BLEXBot|PetalBot|YandexBot|Bytespider|GPTBot|ClaudeBot|CCBot|DataForSeoBot|Sogou|Baiduspider|MegaIndex|ltx71|Nuclei|sqlmap|nikto|masscan|ZmEu|zgrab|Hakai|Tsunami|LOIC|w3af|python-requests|python-urllib|Scrapy|HTTrack|wget|curl/|Go-http-client|httpx|axios|node-fetch|PhantomJS|HeadlessChrome|Puppeteer|Selenium|Playwright) [NC]
RewriteRule .* - [F,L]

# ── Block empty User-Agent hitting PHP endpoints ──
RewriteCond %{HTTP_USER_AGENT} ^-?$
RewriteRule ^(index\.php|api/) - [F,L]

# ── Favicon: return 204 if no file exists (ZERO PHP) ──
RewriteCond %{REQUEST_URI} favicon\.ico$ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule .* - [R=204,L]

# ── NEUTERED ENDPOINTS: return 204 at server level (ZERO PHP) ──
# event.php and track.php are stubs (PostHog migration).
# AdsBot-Google hammers event.php wasting PHP workers.
# Return 204 No Content without ever touching PHP.
RewriteCond %{REQUEST_URI} ^/api/event\.php$ [NC,OR]
RewriteCond %{REQUEST_URI} ^/api/track\.php$ [NC]
RewriteRule .* - [R=204,L]

# ── Block Google-Read-Aloud and similar bots from API endpoints ──
RewriteCond %{HTTP_USER_AGENT} (Google-Read-Aloud|Googlebot-Image|Google-InspectionTool) [NC]
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteRule .* - [F,L]

# ── Protect sensitive API endpoints ──
RewriteCond %{REQUEST_URI} ^/api/health-check\.php$ [NC]
RewriteCond %{HTTP_REFERER} !aniversariodomes\.shop [NC]
RewriteRule .* - [F,L]

RewriteCond %{REQUEST_URI} ^/api/cron-skalepay\.php$ [NC]
RewriteCond %{QUERY_STRING} !key=ml2025
RewriteRule .* - [F,L]

RewriteCond %{REQUEST_URI} ^/api/cron-cleanup\.php$ [NC]
RewriteCond %{QUERY_STRING} !key=ml2025
RewriteRule .* - [F,L]

# ============================================
# LAYER 2: CLOAKER REDIRECT (ZERO PHP!!!)
#
# THIS IS THE CRITICAL OPTIMIZATION.
# Previously: every TikTok ad click invoked PHP (index.php)
#   = 1 PHP worker consumed per landing page visit
#   = 40 workers exhausted under load = 503 for EVERYONE
#
# NOW: LiteSpeed handles the 302 redirect at SERVER LEVEL
#   = ZERO PHP workers for landing pages
#   = Capacity: unlimited (limited only by LiteSpeed, not PHP)
#   = TikTok pre-renders, real clicks, retries — ALL handled
#     without touching PHP
#
# Bot blocking already done in Layer 1 above.
# GeoIP blocking disabled ($block_non_br = false).
# index.php kept as fallback but should NEVER be reached.
# ============================================

# Root path (/ or /index.php) on ANY host → redirect to VSL
# QSA preserves all UTM parameters (utm_source, ttclid, etc.)
RewriteCond %{REQUEST_URI} ^/?$ [OR]
RewriteCond %{REQUEST_URI} ^/index\.php$
RewriteRule ^.*$ https://www.aniversariodomes.shop/vsl/ [R=302,L,QSA]

# ============================================
# LAYER 3: Canonical Host Redirect
# Only for NON-ROOT paths (root already handled above)
# ============================================

# ANY non-canonical domain -> https://www (302 preserva UTMs)
RewriteCond %{HTTP_HOST} !^www\.aniversariodomes\.shop$ [NC]
RewriteRule ^(.*)$ https://www.aniversariodomes.shop/$1 [R=302,L,QSA]

# ============================================
# LAYER 4: Performance & Caching
# ============================================

# ── Compression (LiteSpeed handles this natively, but explicit helps) ──
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── Browser caching ──
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType font/woff2 "access plus 30 days"
    ExpiresByType font/woff "access plus 30 days"
    ExpiresByType application/font-woff2 "access plus 30 days"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ── Cache-Control headers ──
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|woff2|woff|png|jpg|jpeg|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=604800, immutable"
    </FilesMatch>

    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>

    <FilesMatch "\.php$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>

    # Security headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Allow robots.txt ──
<Files "robots.txt">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</Files>

# ── Block access to sensitive files ──
<FilesMatch "\.(json|log|md|cjs|sh|mmdb)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

# ── Block hidden files ──
RewriteRule (^|/)\.(?!well-known) - [F,L]

# ── ETag ──
FileETag MTime Size

# ── Custom 503 error page ──
# SMART: Only redirect to VSL for root/funnel pages.
# /api/ endpoints and /painel/ show "retry" message (NO redirect).
# NO auto-refresh retry storm. Funnel pages redirect to static VSL.
ErrorDocument 503 "<html><head><meta charset='utf-8'><title>Carregando...</title><style>body{font-family:Arial,sans-serif;background:#f8f9fa;display:flex;align-items:center;justify-content:center;height:100vh;margin:0;text-align:center}.c{max-width:400px}h2{color:#333;margin-bottom:8px}p{color:#666;font-size:14px}.s{display:inline-block;width:40px;height:40px;border:4px solid #e9ecef;border-top:4px solid #007bff;border-radius:50%;animation:spin 1s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}</style></head><body><div class='c'><div class='s'></div><h2 id='t'>Carregando...</h2><p id='d'>Aguarde um momento...</p></div><script>var p=location.pathname||'/';if(p.indexOf('/api/')===0||p.indexOf('/painel')===0){document.getElementById('t').textContent='Servidor ocupado';document.getElementById('d').textContent='Aguarde alguns segundos e tente novamente.';document.querySelector('.s').style.display='none';}else{setTimeout(function(){location.href='https://www.aniversariodomes.shop/vsl/'+(location.search||'');},3000);}</script></body></html>"
